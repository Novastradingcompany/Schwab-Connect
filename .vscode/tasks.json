{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Install Dependencies",
      "type": "process",
      "command": "python",
      "args": [
        "-m",
        "pip",
        "install",
        "-r",
        "requirements.txt"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Run Dashboard",
      "type": "process",
      "command": "python",
      "args": [
        "-m",
        "flask",
        "--app",
        "app.py",
        "run",
        "--host",
        "127.0.0.1",
        "--port",
        "8001",
        "--debug"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PYTHONUNBUFFERED": "1"
        }
      },
      "isBackground": true,
      "problemMatcher": [
        {
          "pattern": [
            {
              "regexp": "^(.*)$",
              "message": 1
            }
          ],
          "background": {
            "activeOnStart": true,
            "beginsPattern": ".*",
            "endsPattern": "\\* Running on http://127\\.0\\.0\\.1:8001|\\* Debugger is active!"
          }
        }
      ]
    },
    {
      "label": "Run Schwab Auth Flow",
      "type": "process",
      "command": "python",
      "args": [
        "connect.py"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PYTHONUNBUFFERED": "1"
        }
      },
      "problemMatcher": []
    },
    {
      "label": "Validate Python",
      "type": "process",
      "command": "python",
      "args": [
        "-m",
        "compileall",
        "-q",
        "app.py",
        "connect.py",
        "nova",
        "scripts/render_token_b64.py"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Render Token Base64",
      "type": "process",
      "command": "python",
      "args": [
        "scripts/render_token_b64.py"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
